{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Dokky",
  "version": "0.1.3",
  "identifier": "com.dokky.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Dokky",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/scrcpy-server.jar": "resources/scrcpy-server.jar",
      "resources/apktool.jar": "resources/apktool.jar",
      "resources/apksigner.jar": "resources/apksigner.jar",
      "resources/bin/": "resources/bin/",
      "resources/jre/": "resources/jre/"
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
